using Microsoft.AspNetCore.Mvc;
using Microsoft.AspNetCore.Authorization;
using System.Security.Claims;

namespace ReactApp2test.Server.Controllers
{
    [Route("")]
    public class SiteController : Controller
    {
        [HttpGet("public")]
        [AllowAnonymous]
        public IActionResult Public()
        {
            var html = @"<!doctype html>
<html>
<head>
  <meta charset=\"utf-8\" />
  <title>Public</title>
</head>
<body>
  <h2>Public Page</h2>
  <p><a href=\"/auth/login\">Login</a></p>
  <p><a href=\"/user\">User Page (requires User role)</a></p>
  <p><a href=\"/admin\">Admin Page (requires Admin role)</a></p>
  <p><a href=\"/auth/logout\">Logout</a></p>
</body>
</html>";
            return Content(html, "text/html");
        }

        [HttpGet("user")]
        [Authorize(Roles = "User")]
        public IActionResult UserPage()
        {
            var name = User.Identity?.Name ?? "(unknown)";
            var roles = string.Join(", ", User.Claims.Where(c => c.Type == ClaimTypes.Role).Select(c => c.Value));
            var html = $@"<!doctype html>
<html>
<head>
  <meta charset=\"utf-8\" />
  <title>User Page</title>
</head>
<body>
  <h2>User Page</h2>
  <p>Welcome, {name}</p>
  <p>Roles: {roles}</p>
  <p><a href=\"/public\">Back</a></p>
</body>
</html>";
            return Content(html, "text/html");
        }

        [HttpGet("admin")]
        [Authorize(Roles = "Admin")]
        public IActionResult AdminPage()
        {
            var name = User.Identity?.Name ?? "(unknown)";
            var roles = string.Join(", ", User.Claims.Where(c => c.Type == ClaimTypes.Role).Select(c => c.Value));
            var html = $@"<!doctype html>
<html>
<head>
  <meta charset=\"utf-8\" />
  <title>Admin Page</title>
</head>
<body>
  <h2>Admin Page</h2>
  <p>Welcome, {name}</p>
  <p>Roles: {roles}</p>
  <p><a href=\"/public\">Back</a></p>
</body>
</html>";
            return Content(html, "text/html");
        }
    }
}
